PORT=3000

# Persist contact form rows in PostgreSQL (default / unset = off, email only)
# Set to true when DATABASE_URL is configured and you want DB + email
CONTACT_STORE_IN_DB=false

# PostgreSQL connection string (required only when CONTACT_STORE_IN_DB=true)
# Example: postgres://username:password@localhost:5432/techcapital
DATABASE_URL=
PG_SSL=false

# SMTP settings for sending notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Destination inbox for contact notifications
CONTACT_TO_EMAIL=sorin.smalley@techCapitalSolutions.net

# Protect GET /api/admin/submissions (use a long random string)
ADMIN_API_TOKEN=

# Rate limit for POST /api/contact (per IP; in-memory on this server instance)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Set to 1 if app runs behind a reverse proxy (nginx, etc.) so client IP is correct
TRUST_PROXY=false

# CORS: comma-separated origins allowed to call this API (required for GitHub Pages + separate API host)
# Example: https://yourname.github.io,https://www.yourdomain.com
ALLOWED_ORIGINS=
